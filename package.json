{
  "name": "@olli/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for olli.social — AI-powered social media management platform",
  "type": "module",
  "bin": {
    "olli-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
