    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ejwhite7/olli-mcp.git"
  },
  "homepage": "https://github.com/ejwhite7/olli-mcp#readme",
  "bugs": {
    "url": "https://github.com/ejwhite7/olli-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": ["mcp", "model-context-protocol", "olli", "social-media", "linkedin", "ai", "claude"]
